{
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index"
    },
    {
      "source": "/api/scrape",
      "destination": "/api/scrape"
    }
  ],
  "functions": {
    "api/scrape.js": {
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api/scrape?type=ping",
      "schedule": "*/10 * * * *"
    }
  ]
}
